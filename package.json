{
  "name": "@yawlabs/mcp",
  "version": "0.58.0",
  "mcpName": "io.github.YawLabs/mcp",
  "description": "Yaw MCP -- MCP servers, managed. Run locally, sync across machines with Pro.",
  "license": "UNLICENSED",
  "author": "Yaw Labs <support@yaw.sh> (https://yaw.sh/mcp)",
  "type": "module",
  "bin": {
    "yaw-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test:ci": "npm run build && npm test",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^7.8.0"
  },
  "overrides": {
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "orchestrator",
    "mcp-server",
    "ai",
    "yaw",
    "yaw-mcp",
    "yawlabs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YawLabs/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/YawLabs/mcp/issues"
  },
  "homepage": "https://yaw.sh/mcp"
}
