    "hono": "^4.12.14",
    "qs": "^6.15.2",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^26.0.0",
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6",
    "tsup": "^8.4.0",
